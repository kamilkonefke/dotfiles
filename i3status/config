general {
    colors = true
    interval = 5
}

order += "ethernet _first_"
order += "memory"
order += "tztime local"

ethernet _first_ {
    format_up = "IPv4 %ip"
    format_down = "E: down"
}

memory {
    format = "IN USE: %used | FREE: %available"
    threshold_degraded = "1G"
    format_degraded = "MEMORY < %available"
}

tztime local {
    format = "%d %b %H:%M"
}
